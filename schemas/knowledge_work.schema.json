    },
    "title": { "type": "string" },
    "central_question": { "type": "string" },
    "core_thesis": { "type": "string" },
    "audience": { "type": "string" },
    "intended_effect": { "type": "string" },
    "source_index_ids": { "type": "array", "items": { "type": "string" } },
    "source_note_ids": { "type": "array", "items": { "type": "string" } },
    "writing_project_ids": { "type": "array", "items": { "type": "string" } },
    "status": {
      "type": "string",
      "enum": ["seed", "structuring", "drafting", "revising", "published", "archived"]
