{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "target",
    "scope",
    "content",
    "status",
    "origin",
    "created_at",
    "updated_at",
    "model",
    "provenance",
    "history"
  ],
  "properties": {
    "id": { "type": "string" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "id"],
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" },
        "field": { "type": "string" }
      }
    },
    "scope": { "type": "string" },
    "content": {},
    "status": {
      "type": "string",
      "enum": ["suggested", "adopted_as_draft", "rejected", "edited", "confirmed"]
    },
    "origin": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "model": { "type": ["object", "string", "null"] },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content_origin", "human_confirmed", "human_edited"],
      "properties": {
        "content_origin": { "type": "string" },
        "human_confirmed": { "type": "boolean" },
        "human_edited": { "type": "boolean" }
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from_status", "to_status", "action", "actor", "user_id", "comment", "created_at"],
        "properties": {
          "from_status": { "type": "string" },
          "to_status": { "type": "string" },
          "action": { "type": "string" },
          "actor": { "type": "string", "enum": ["user", "system", "ai"] },
          "user_id": { "type": "string" },
          "comment": { "type": "string" },
          "created_at": { "type": "string" }
        }
      }
    }
  }
}
